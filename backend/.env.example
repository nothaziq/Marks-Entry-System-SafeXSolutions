# PostgreSQL connection
DATABASE_URL=postgresql://attendance_user:attendance_pass@localhost:5432/attendance_db

# JWT
SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# Gmail SMTP - used to send the daily attendance reminder emails.
# GMAIL_APP_PASSWORD must be a Gmail "App Password", NOT your normal Gmail
# password. Generate one at: Google Account -> Security -> 2-Step
# Verification (must be enabled first) -> App Passwords.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_SENDER_NAME=

# Daily reminder job schedule (24-hour, server-local time)
REMINDER_HOUR=17
REMINDER_MINUTE=0
