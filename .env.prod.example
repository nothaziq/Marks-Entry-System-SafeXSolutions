# Copy this to .env.prod and fill in real values before deploying with:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build -d

# Postgres password - pick a strong one, this isn't the localhost dev default
DB_PASSWORD=

# JWT signing key - generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Your real deployed URLs (no trailing slash)
FRONTEND_URL=https://attendance.yourdomain.com
API_URL=https://api.yourdomain.com

# Gmail SMTP for the daily reminder emails (optional - leave blank to
# disable email sending; the app degrades gracefully without it)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_SENDER_NAME=Marks Entry System

# Daily reminder job schedule (24-hour, server-local time)
REMINDER_HOUR=17
REMINDER_MINUTE=0
